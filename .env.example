# Copy to .env and fill in your values
GH_TOKEN=ghp_your_github_token
ANTHROPIC_API_KEY=sk-ant-your-key
GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=claude

# Ollama base URL (only needed when LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://ollama:11434            # both in Docker Compose (default)
# OLLAMA_BASE_URL=http://host.docker.internal:11434  # agent in Docker, Ollama on host
# OLLAMA_BASE_URL=http://localhost:11434          # both running locally, no Docker

# Per-repo tokens for private repositories (optional)
# Use fine-grained PATs scoped to specific repos for better security.
# The env var name must match the token_env value in config.yaml.
MY_PRIVATE_REPO_TOKEN=ghp_your_private_repo_token

# LangSmith tracing (optional)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_your_langsmith_key
# LANGSMITH_PROJECT=coding-agent
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
